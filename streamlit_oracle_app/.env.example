# Driver JDBC local
ORACLE_JDBC_JAR=jdbc/ojdbc8.jar

# Nodos RAC o nodos Oracle disponibles
# Formato: host:puerto:sid,host:puerto:sid
ORACLE_TARGETS=172.16.60.20:1521:prdsgh1,172.16.60.21:1521:prdsgh2

# Concurrencia máxima para consultas pesadas
MAX_WORKERS=8

# Límite defensivo de filas
DEFAULT_MAX_ROWS=500
